FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_with_local_secret
FEISHU_BASE_URL=https://open.feishu.cn

# Weekly scheduler settings. Default is disabled.
FEISHU_WEEKLY_SEND_ENABLED=false
FEISHU_WEEKLY_ENV_FILE=.env.local
FEISHU_WEEKLY_SHEET_URL=https://tenant.feishu.cn/wiki/xxx?sheet=xxxxxx
FEISHU_WEEKLY_RANGE=A1:C16

# Recommended recipient format. It supports mixed id types and email lookup.
# Examples: user_id:12139762,open_id:ou_xxx,email:person@example.com
FEISHU_WEEKLY_RECIPIENTS=
FEISHU_WEEKLY_EMAIL_LOOKUP_ID_TYPE=open_id

# Legacy recipient format. Keep empty when FEISHU_WEEKLY_RECIPIENTS is used.
FEISHU_WEEKLY_RECEIVE_ID=
FEISHU_WEEKLY_RECEIVE_IDS=
FEISHU_WEEKLY_RECEIVE_ID_TYPE=user_id

FEISHU_WEEKLY_TITLE=项目进展
FEISHU_WEEKLY_MESSAGE_FORMAT=card
FEISHU_WEEKLY_SHOW_ALL_MILESTONES=false
FEISHU_WEEKLY_DEBUG=false

# Optional contact cache. Use contact_cache.py to refresh contacts_cache.json manually.
FEISHU_CONTACT_CACHE_ENABLED=false
FEISHU_CONTACT_CACHE_PATH=contacts_cache.json
FEISHU_CONTACT_DEPARTMENT_ID=0
FEISHU_CONTACT_DEPARTMENT_ID_TYPE=department_id
FEISHU_CONTACT_PAGE_SIZE=50
